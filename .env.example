# Database Configuration
DB_TYPE=postgresql
PG_HOST=localhost
PG_PORT=5432
PG_USER=healthconnect
PG_PASSWORD=CHANGE_ME_TO_STRONG_PASSWORD
PG_DATABASE=healthconnect

# Server settings
HOST=0.0.0.0
PORT=8000
RELOAD=false
WORKERS=4

# CORS (your domain, comma-separated)
CORS_ORIGINS=https://yourdomain.com,http://yourdomain.com

# ML Models
MODELS_DIR=/home/youruser/backend/models

# Logging
LOG_LEVEL=INFO
